# FastAPI 服务配置
HOST=127.0.0.1
PORT=23001

# Nexos 入口地址
NEXOS_BASE_URL=https://workspace.nexos.ai

# 账号配置文件（每个账号含 cookies + model_mapping）
NEXOS_ACCOUNTS_FILE=./nexos_accounts.json

# 当前会话持久化文件（按账号存储）
CURRENT_CHAT_FILE=./current-chat.json

# 是否默认禁用历史记录（true/false）
DISABLE_HISTORY=true

# 请求超时（秒）
NEXOS_TIMEOUT=120
